SP_ENTITY_ID=http://localhost:8000/metadata
SP_ACS_URL=http://localhost:8000/acs
SP_SLS_URL=http://localhost:8000/sls

# Name of the SAML attribute that carries roles — differs per IdP:
#   Keycloak default  : Role
#   Azure AD / Entra  : http://schemas.microsoft.com/ws/2008/06/identity/claims/role
#   Okta / Auth0      : roles  (or groups)
#   AD FS             : http://schemas.xmlsoap.org/claims/Group
SAML_ROLE_ATTRIBUTE=Role

# Map IdP role values → app role values.
# Format : pipe-separated  idp_role:app_role  pairs.
# Use "|" between pairs so role names containing commas (e.g. LDAP DNs) are safe.
# Leave empty to pass all IdP roles through unchanged.
# When set, only listed roles are kept; unlisted roles are dropped.
SAML_ROLE_MAP=default-roles-saml-demo:user|uma_authorization:admin|offline_access:user
